APP_NAME=SentinelForge EDR Ingest API
ENVIRONMENT=local
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
SERVICE_NAME=ingest-api

INGEST_SHARED_TOKEN=sentinel-ingest-dev-token

DB_URL=postgresql+asyncpg://sentinel:sentinel1@localhost:5433/sentinelforge
DB_MIGRATION_URL=postgresql+psycopg://sentinel:sentinel1@localhost:5433/sentinelforge

KAFKA_ENABLE = TRUE
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=sentinelforge-ingest-api
KAFKA_TOPIC_RAW_INGESTED=telemetry.raw.ingested
KAFKA_TOPIC_NORMALIZED=telemetry.normalized
KAFKA_CONSUMER_GROUP_DETECTOR=sentinelforge-detector

NORMALIZATION_VERSION=1.0

METRICS_ENABLED=true
METRICS_NORMALIZER_PORT=9101
METRICS_DETECTOR_PORT=9102